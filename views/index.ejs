<!DOCTYPE html>
<html>
<head>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
body {
    background: linear-gradient(135deg, #1E1A17, #2C2521, #3A2F2A);
    font-family: 'Poppins', sans-serif;
    color: #F5EFE6;
}

.form-container {
    max-width: 640px;
    margin: 90px auto;
    padding: 45px;
    background: #2A2420;
    border-radius: 20px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.5);
}

.title {
    font-family: 'Playfair Display', serif;
    font-size: 30px;
    margin-bottom: 30px;
}

label {
    font-size: 14px;
    margin-bottom: 6px;
    color: #cbbca7;
}

input, textarea {
    background: #1E1A17 !important;
    border: 1px solid rgba(230,211,179,0.15) !important;
    color: #F5EFE6 !important;
    border-radius: 12px;
    padding: 12px;
}

input:focus, textarea:focus {
    border-color: #C6A969 !important;
    box-shadow: 0 0 12px rgba(198,169,105,0.2);
}

.btn-save {
    background: linear-gradient(135deg, #C6A969, #E6D3B3);
    color: #1E1A17;
    border-radius: 12px;
    padding: 12px;
    font-weight: 500;
    border: none;
}
</style>

</head>

<body>

<%- include('./partials/header.ejs') %>

<div class="form-container">

    <h2 class="title">Add New Book</h2>

    <form action="/books/create" method="POST" enctype="multipart/form-data">

        <div class="mb-3">
            <label>Book Title</label>
            <input type="text" name="title" class="form-control">
        </div>

        <div class="mb-3">
            <label>Author</label>
            <input type="text" name="author" class="form-control">
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea name="description" class="form-control"></textarea>
        </div>

        <div class="mb-3">
            <label>Price</label>
            <input type="number" name="price" class="form-control">
        </div>

        <div class="mb-4">
            <label>Book Cover</label>
            <input type="file" name="image" class="form-control">
        </div>

        <button class="btn btn-save w-100">Save Book</button>

    </form>

</div>

</body>
</html>