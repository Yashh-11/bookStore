<!DOCTYPE html>
<html>
<head>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body style="background:#1E1A17; color:white;">

<%- include('./partials/header.ejs') %>

<div class="container mt-5">

<h3>Edit Book</h3>

<form action="/books/update/<%= book._id %>" method="POST" enctype="multipart/form-data">

<div class="mb-3">
<label>Title</label>
<input type="text" name="title" value="<%= book.title %>" class="form-control">
</div>

<div class="mb-3">
<label>Author</label>
<input type="text" name="author" value="<%= book.author %>" class="form-control">
</div>

<div class="mb-3">
<label>Description</label>
<textarea name="description" class="form-control"><%= book.description %></textarea>
</div>

<div class="mb-3">
<label>Price</label>
<input type="number" name="price" value="<%= book.price %>" class="form-control">
</div>

<div class="mb-3">
<label>Change Image</label>
<input type="file" name="image" class="form-control">
</div>

<button class="btn btn-primary">Update Book</button>

<a href="/view" class="btn btn-secondary">Back</a>

</form>

</div>

</body>
</html>